#!/bin/bash

SOURCE_DIRS=("/usr/share/applications" "$HOME/.local/share/applications")
TARGET_DIR="$HOME/.local/share/applications"

mkdir -p "$TARGET_DIR"

for dir in "${SOURCE_DIRS[@]}"; do
    find "$dir" -type f -name "*.desktop" | while read -r file; do
        # Přeskoč duplicity
        base=$(basename "$file")
        target="$TARGET_DIR/$base"

        # Pokud soubor už existuje v ~/.local/share/applications, přeskakujeme
        [ -f "$target" ] && continue

        # Zjisti, jestli aplikace běží v terminálu
        if grep -q '^Terminal=true' "$file"; then
            # Zkopíruj a přidej NoDisplay
            cp "$file" "$target"
            echo "NoDisplay=true" >> "$target"
            echo "Skryt: $base"
        fi
    done
done
