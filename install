#!/bin/bash

sudo pacman -S git sway swaybg swaylock vim alacritty flatpak firefox thunar blueman rofi-wayland brightnessctl fastfetch autotiling base-devel picom feh go waybar --noconfirm

git clone https://aur.archlinux.org/yay.git
cd yay
makepkg -si --noconfirm
cd
mv yay .yay

git clone https://www.github.com/lagantius/linux

rm ~/.bashrc
rm ~/.bash_profile
mv ~/linux/bashrc ~/.bashrc
mv ~/linux/bash_profile ~/.bash_profile
source ~/.bashrc

mkdir ~/.config/wallpaper
mv ~/linux/arch-pacman.png ~/.config/wallpaper/

mkdir ~/.config/alacritty
mv ~/linux/alacritty ~/.config/alacritty/alacritty.toml

mkdir ~/.config/fastfetch
mv ~/linux/fastfetch ~/.config/fastfetch/config.jsonc

mkdir ~/.config/sway
mv ~/linux/sway ~/.config/sway/config

mkdir ~/.config/rofi
mv ~/linux/rofi ~/.config/rofi/config.rasi

rm -rf ~/linux
